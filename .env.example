# Local development environment for the Lattice app

# Supabase configuration (required for app initialization)
EXPO_PUBLIC_SUPABASE_URL=http://localhost:8787
EXPO_PUBLIC_SUPABASE_ANON_KEY=anon

# Optional local proxy override
EXPO_PUBLIC_USE_LOCAL_AI_PROXY=true
EXPO_PUBLIC_LOCAL_AI_PROXY_URL=http://localhost:8787/functions/v1/azl-agent
